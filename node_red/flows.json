    {
        "id": "f6f516d89fba539b",
        "type": "function",
        "z": "b8774ea65c27b37b",
        "name": "Combine Temp & Humidity",
        "func": "let temp = context.get('temp');\nlet hum = context.get('hum');\n\nlet line = msg.payload.trim();\n\n// Parse temperature\nif (line.startsWith('Temperature')) {\n    let value = line.split('=')[1].replace('C', '').trim();\n    temp = parseFloat(value);\n    context.set('temp', temp);\n}\n\n// Parse humidity\nif (line.startsWith('Humidity')) {\n    let value = line.split('=')[1].replace('%', '').trim();\n    hum = parseFloat(value);\n    context.set('hum', hum);\n}\n\n// Wait until both temp and humidity are available\nif (temp !== undefined && hum !== undefined) {\n    const timestamp = new Date().toISOString();\n\n    const alerts = {\n        high_temp: temp > 30,\n        low_temp: temp < 15,\n        warn_temp: (temp >= 27 && temp <= 30) || (temp >= 15 && temp < 18),\n\n        high_humidity: hum > 70,\n        low_humidity: hum < 30,\n        warn_humidity: (hum >= 65 && hum <= 70) || (hum >= 30 && hum < 35)\n    };\n\n    let alertMsgs = [];\n\n    if (alerts.high_temp) alertMsgs.push(`High temperature: ${temp.toFixed(1)}°C`);\n    else if (alerts.low_temp) alertMsgs.push(`Low temperature: ${temp.toFixed(1)}°C`);\n    else if (alerts.warn_temp) alertMsgs.push(`Temperature approaching limit: ${temp.toFixed(1)}°C`);\n\n    if (alerts.high_humidity) alertMsgs.push(`High humidity: ${hum.toFixed(1)}%`);\n    else if (alerts.low_humidity) alertMsgs.push(`Low humidity: ${hum.toFixed(1)}%`);\n    else if (alerts.warn_humidity) alertMsgs.push(`Humidity approaching limit: ${hum.toFixed(1)}%`);\n\n    msg.payload = {\n        tray_id: \"Tray 1\",\n        temperature: temp,\n        humidity: hum,\n        timestamp,\n        alerts,\n        status: alertMsgs.length > 0 ? alertMsgs.join(', ') : \"OK\"\n    };\n\n    return msg;\n}\n\nreturn null;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
