    {
        "id": "3f9fa2784beb0bdc",
        "type": "function",
        "z": "b8774ea65c27b37b",
        "name": "Format Env Payload",
        "func": "const temp = msg.payload.temperature;\nconst hum = msg.payload.humidity;\nconst alerts = msg.payload.alerts || {};\n\nlet alertMsgs = [];\nif (alerts.high_temp) alertMsgs.push(`High temperature: ${temp}°C`);\nif (alerts.low_temp) alertMsgs.push(`Low temperature: ${temp}°C`);\nif (alerts.high_humidity) alertMsgs.push(`High humidity: ${hum}%`);\nif (alerts.low_humidity) alertMsgs.push(`Low humidity: ${hum}%`);\n\nmsg.payload = {\n    temperature: temp,\n    humidity: hum,\n    alerts,\n    status: alertMsgs.length > 0 ? alertMsgs.join(', ') : \"OK\"\n};\n\nreturn msg;\n",
